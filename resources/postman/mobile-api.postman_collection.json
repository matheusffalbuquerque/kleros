    },
    {
      "name": "Sincronização",
      "item": [
        {
          "name": "Delta de dados",
          "request": {
            "method": "GET",
            "header": [
              {"key": "Authorization", "value": "Bearer {{token}}"},
              {"key": "X-Congregacao-Codigo", "value": "1"}
            ],
            "url": {
              "raw": "{{api_url}}/api/sincronizar?lastSync=1970-01-01T00:00:00Z",
              "host": ["{{api_url}}"],
              "path": ["api", "sincronizar"],
              "query": [
                {"key": "lastSync", "value": "1970-01-01T00:00:00Z"}
              ]
            }
          }
        }
      ]
    }
