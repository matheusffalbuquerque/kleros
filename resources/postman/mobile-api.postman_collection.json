{
  "info": {
    "name": "Kleros Mobile API",
    "description": "Coleção para testar a API móvel multitenant do Kleros.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_postman_id": "4f4fd7f6-8f1d-4b5f-a9a2-collection"
  },
  "variable": [
    {"key": "api_url", "value": "http://localhost:8000"},
    {"key": "token", "value": ""},
    {"key": "noticia_id", "value": "1"},
    {"key": "podcast_id", "value": "1"},
    {"key": "livro_id", "value": "1"}
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "X-Congregacao-Codigo", "value": "1"}
            ],
            "url": {
              "raw": "{{api_url}}/api/login",
              "host": ["{{api_url}}"],
              "path": ["api", "login"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@kleros.com\",\n  \"password\": \"password\",\n  \"device_name\": \"postman\"\n}"
            }
          }
        },
        {
          "name": "Registro",
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "X-Congregacao-Codigo", "value": "1"}
            ],
            "url": {
              "raw": "{{api_url}}/api/registro",
              "host": ["{{api_url}}"],
              "path": ["api", "registro"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Membro Mobile\",\n  \"email\": \"mobile@example.com\",\n  \"password\": \"password\",\n  \"telefone\": \"(11)90000-0000\"\n}"
            }
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Authorization", "value": "Bearer {{token}}"},
              {"key": "X-Congregacao-Codigo", "value": "1"}
            ],
            "url": {
              "raw": "{{api_url}}/api/logout",
              "host": ["{{api_url}}"],
              "path": ["api", "logout"]
            }
          }
        }
      ]
    },
    {
      "name": "Configuração",
